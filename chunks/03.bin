-secondary); }
.result-card { background: var(--bg-card); border-radius: var(--radius); padding: 2rem; text-align: center; margin-bottom: 1.5rem; border: 1px solid var(--border); }
.personality-emoji { font-size: 4rem; margin-bottom: 1rem; }
.result-description { color: var(--text-secondary); line-height: 1.7; font-size: 1.05rem; }
.dimensions-result { background: var(--bg-card); border-radius: var(--radius); padding: 1.5rem; margin-bottom: 1.5rem; border: 1px solid var(--border); }
.dimension-row { margin-bottom: 1.25rem; }
.dimension-row:last-child { margin-bottom: 0; }
.dimension-labels { display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.9rem; }
.dimension-labels .left { color: var(--primary-light); font-weight: 600; }
.dimension-labels .right { color: var(--text-muted); }
.dimension-bar { height: 12px; background: var(--bg-dark); border-radius: 10px; overflow: hidden; }
.dimension-fill { height: 100%; border-radius: 10px; background: var(--gradient-1); transition: width 1s ease; }
.traits-section, .famous-section, .compatibility-section { background: var(--bg-card); border-radius: var(--radius); padding: 1.5rem; margin-bottom: 1.5rem; border: 1px solid var(--border); }
.traits-section h3, .famous-section h3, .compatibility-section h3 { margin-bottom: 1rem; font-size: 1.1rem; }
.traits-list { display: flex; flex-wrap: wrap; gap: 0.75rem; }
.trait-tag { background: rgba(99,102,241,0.15); color: var(--primary-light); padding: 0.5rem 1rem; border-radius: 50px; font-size: 0.9rem; border: 1px solid rgba(99,102,241,0.3); }
.famous-section p, .compatibility-section p { color: var(--text-secondary); line-height: 1.6; }
.action-buttons { display: flex; gap: 1rem; justify-content: center; margin-bottom: 2rem; flex-wrap: wrap; }
.btn-share, .btn-restart { padding: 1rem 2rem; font-size: 1rem; font-weight: 600; border-radius: 50px; cursor: pointer; transition: all 0.3s ease; border: none; }
